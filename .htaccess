# Disable directory browsing

Options -Indexes

# Protect .env files

<FilesMatch "^\.env(\..*)?$">
Require all denied
</FilesMatch>

# Protect local key material and session tracking files

<FilesMatch "^(\.settings_key|sessions\.json)$">
Require all denied
</FilesMatch>

# Protect specific json files that contain sensitive info or are system configs

<FilesMatch "^(accounts|settings|settings_templates|chat|revoked|support_tickets)\.json$">
Require all denied
</FilesMatch>

# Protect log files and backups

<FilesMatch "\.(log|bak|lock|ps1|bat|md)$">
Require all denied
</FilesMatch>

# Route Apache error responses to custom pages

ErrorDocument 400 /400.php
ErrorDocument 401 /401.php
ErrorDocument 403 /403.php
ErrorDocument 404 /404.php
ErrorDocument 405 /405.php
ErrorDocument 408 /408.php
ErrorDocument 429 /429.php
ErrorDocument 500 /500.php
ErrorDocument 502 /502.php
ErrorDocument 503 /503.php
ErrorDocument 504 /504.php

# Auto-track request timing for all PHP pages in this app

<IfModule mod_php.c>
php_value auto_prepend_file "C:/xampp/htdocs/Blockchain-Based-Attendance-System/request_timing_auto.php"
</IfModule>
<IfModule mod_php8.c>
php_value auto_prepend_file "C:/xampp/htdocs/Blockchain-Based-Attendance-System/request_timing_auto.php"
</IfModule>
