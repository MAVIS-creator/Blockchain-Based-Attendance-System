# Disable directory browsing

Options -Indexes

# Protect .env files

<FilesMatch "^\.env(\..\*)?$">
Require all denied
</FilesMatch>

# Protect local key material and session tracking files

<FilesMatch "^(\.settings_key|sessions\.json)$">
Require all denied
</FilesMatch>

# Protect specific json files that contain sensitive info or are system configs

<FilesMatch "^(accounts|settings|settings_templates|chat|revoked|support_tickets)\.json$">
Require all denied
</FilesMatch>

# Protect log files and backups

<FilesMatch "\.(log|bak|lock|ps1|bat|md)$">
Require all denied
</FilesMatch>
