<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <!-- Enable detailed error logging -->
    <httpErrors errorMode="DetailedLocalOnly" defaultPath="/error_template.php">
      <!-- Map HTTP error codes to custom error pages -->
      <error statusCode="400" path="/400.php" responseMode="ExecuteURL" />
      <error statusCode="401" path="/401.php" responseMode="ExecuteURL" />
      <error statusCode="403" path="/403.php" responseMode="ExecuteURL" />
      <error statusCode="404" path="/404.php" responseMode="ExecuteURL" />
      <error statusCode="405" path="/405.php" responseMode="ExecuteURL" />
      <error statusCode="408" path="/408.php" responseMode="ExecuteURL" />
      <error statusCode="429" path="/429.php" responseMode="ExecuteURL" />
      <error statusCode="500" path="/500.php" responseMode="ExecuteURL" />
      <error statusCode="502" path="/502.php" responseMode="ExecuteURL" />
      <error statusCode="503" path="/503.php" responseMode="ExecuteURL" />
      <error statusCode="504" path="/504.php" responseMode="ExecuteURL" />
    </httpErrors>

    <!-- Rewrite Rules (URL rewriting for PHP routing) -->
    <rewrite>
      <rules>
        <!-- Skip rewriting for actual files and directories -->
        <rule name="Skip Existing Files" stopProcessing="true">
          <match url="^(.*)$" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" />
          </conditions>
          <action type="None" />
        </rule>
        <rule name="Skip Existing Directories" stopProcessing="true">
          <match url="^(.*)$" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" />
          </conditions>
          <action type="None" />
        </rule>
        <!-- Rewrite to index.php for router -->
        <rule name="Route Requests to Router" stopProcessing="true">
          <match url="^(.*)$" />
          <action type="Rewrite" url="index.php" />
        </rule>
      </rules>
    </rewrite>

    <!-- Security Headers -->
    <httpProtocol>
      <customHeaders>
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="X-Frame-Options" value="DENY" />
        <add name="X-XSS-Protection" value="1; mode=block" />
        <add name="Strict-Transport-Security" value="max-age=31536000; includeSubDomains" />
      </customHeaders>
    </httpProtocol>

    <!-- Restrict file/folder access -->
    <directoryBrowse enabled="false" />

    <!-- PHP Handler Configuration -->
    <handlers>
      <add name="PHP" path="*.php" verb="*" modules="FastCgiModule" scriptProcessor="D:\Program Files\PHP\v8.2\php-cgi.exe" resourceType="Either" requireAccess="Script" />
    </handlers>

    <!-- Compression -->
    <urlCompression doStaticCompression="true" doDynamicCompression="true" />

    <!-- Request Filtering (security) -->
    <security>
      <requestFiltering>
        <hiddenSegments>
          <add segment=".env" />
          <add segment=".env.local" />
          <add segment=".settings_key" />
          <add segment="storage" />
          <add segment="vendor" />
          <add segment=".git" />
        </hiddenSegments>
        <fileExtensions>
          <add fileExtension=".env" allowed="false" />
          <add fileExtension=".json" allowed="false" />
          <add fileExtension=".lock" allowed="false" />
        </fileExtensions>
      </requestFiltering>
    </security>
  </system.webServer>

  <!-- PHP Settings -->
  <appSettings>
    <add key="WEBSITE_PHP_HANDLER_VERSION" value="8.2" />
  </appSettings>
</configuration>
