# Local overrides for development only.
# Copy to `.env.local` on localhost. Values here override `.env` when APP_ENV is local/development
# or when the request runs on localhost / 127.0.0.1 / ::1.

APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost/Blockchain-Based-Attendance-System

# Keep local runtime data out of the repo tree if you want:
STORAGE_PATH=

# Disable external integrations locally unless explicitly testing them
HYBRID_MODE=off
HYBRID_ADMIN_READ=false
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Local SMTP override
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=tls
