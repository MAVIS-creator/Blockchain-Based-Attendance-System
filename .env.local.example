# Local overrides for development only.
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost/Blockchain-Based-Attendance-System

LOCALHOST_MODE=true
LOCAL_STORAGE_PATH=

HYBRID_MODE=off
HYBRID_ADMIN_READ=false
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=tls

PATCHER_AI_ENABLED=true
PATCHER_AI_PROVIDER=openrouter
PATCHER_OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
PATCHER_OPENROUTER_API_KEY=
PATCHER_OPENROUTER_MODEL=openrouter/free
PATCHER_GEMINI_API_KEY=
PATCHER_GEMINI_MODEL=gemini-2.0-flash

# AI Ticket Automation Provider
# Provider modes: rules | groq | openrouter | gemini | auto
AI_AUTOMATION_PROVIDER=auto
AI_VERIFICATION_LINK=
AI_AUTOMATION_TIMEOUT_SECONDS=8

AI_SITE_CONTEXT_ENABLED=true
AI_SITE_CONTEXT_MAX_CHARS=3000
AI_SITE_CONTEXT_SCAN_ENABLED=true
AI_SITE_CONTEXT_SCAN_INCLUDE=*.php,*.md
AI_SITE_CONTEXT_SCAN_EXCLUDE=vendor/,storage/logs/,storage/backups/,admin/backups/,storage/admin/
AI_SITE_CONTEXT_MAX_FILES=350

GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_FAST_MODELS=llama-3.1-8b-instant,llama-3.3-70b-versatile

AI_OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
AI_OPENROUTER_API_KEY=
AI_OPENROUTER_MODEL=openrouter/auto

AI_GEMINI_API_KEY=
AI_GEMINI_MODEL=gemini-2.0-flash
