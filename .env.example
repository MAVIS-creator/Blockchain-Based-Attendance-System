# Blockchain-Based Attendance System - Environment Configuration
# Copy this file to .env and configure your settings
# For localhost overrides, copy `.env.local.example` to `.env.local`.

# ==============================================
# SMTP Email Configuration
# ==============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_SECURE=tls

# Email sender details
FROM_EMAIL=no-reply@example.com
FROM_NAME=Attendance System

# Auto-send logs recipient (optional)
AUTO_SEND_RECIPIENT=admin@university.edu

# ==============================================
# Polygon Blockchain Configuration (Optional)
# ==============================================
# Enable blockchain integration
BLOCKCHAIN_ENABLED=false

# Polygon network RPC URL
POLYGON_RPC_URL=https://polygon-rpc.com

# Smart contract address for storing hashes
POLYGON_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Private key for signing transactions (KEEP SECRET!)
POLYGON_PRIVATE_KEY=your-private-key-here

# ==============================================
# Application Settings
# ==============================================
# Application environment (development, production)
APP_ENV=development

# Debug mode (true/false)
APP_DEBUG=true

# Application URL
APP_URL=http://localhost/Blockchain-Based-Attendance-System

# Session lifetime in minutes
SESSION_LIFETIME=120

# ==============================================
# Security Settings
# ==============================================
# Enable IP whitelisting (true/false)
IP_WHITELIST_ENABLED=false

# Comma-separated list of allowed IP addresses
IP_WHITELIST=192.168.1.1,192.168.1.2

# Enable device fingerprinting (true/false)
FINGERPRINT_ENABLED=true

# ==============================================
# Attendance Settings
# ==============================================
# Maximum check-ins per day per student
MAX_CHECKINS_PER_DAY=1

# Require reason for attendance (true/false)
REQUIRE_REASON=false

# Check-in time window (24-hour format HH:MM)
CHECKIN_TIME_START=08:00
CHECKIN_TIME_END=18:00

# ==============================================
# Admin Settings
# ==============================================
# Maximum number of admin accounts
MAX_ADMINS=5

# Session timeout in minutes
ADMIN_SESSION_TIMEOUT=30

# ==============================================
# File Storage
# ==============================================
# Log directory path (relative to root)
LOG_DIR=admin/logs

# Backup directory path (relative to root)
BACKUP_DIR=admin/backups

# Secure logs directory (for blockchain)
SECURE_LOG_DIR=secure_logs

# ==============================================
# Hybrid File + Supabase (Optional)
# ==============================================
# Modes: off | dual_write
HYBRID_MODE=off

# Use Supabase as preferred admin read source when dual_write is enabled
HYBRID_ADMIN_READ=true

# Optional shared storage root (for outbox and fail-safe sync files)
STORAGE_PATH=

# Supabase project URL (no trailing slash)
SUPABASE_URL=

# Supabase service role key (KEEP SECRET!)
SUPABASE_SERVICE_ROLE_KEY=

# ==============================================
# Advanced Settings
# ==============================================
# Timezone
APP_TIMEZONE=Africa/Lagos

# Date format
DATE_FORMAT=Y-m-d

# Time format
TIME_FORMAT=H:i:s

# Enable encryption for settings (true/false)
ENCRYPT_SETTINGS=false

# ==============================================
# Localhost Override Mode
# ==============================================
# On localhost only, this can temporarily override production-style values
# without changing the values above.
LOCALHOST_MODE=false
LOCAL_STORAGE_PATH=

# ==============================================
# Patcher Studio AI
# ==============================================
PATCHER_AI_ENABLED=true
PATCHER_AI_PROVIDER=openrouter
PATCHER_OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
PATCHER_OPENROUTER_API_KEY=
PATCHER_OPENROUTER_MODEL=openrouter/free
PATCHER_GEMINI_API_KEY=
PATCHER_GEMINI_MODEL=gemini-2.0-flash

# ==============================================
# AI Ticket Automation Provider
# ==============================================
# Provider modes: rules | groq | openrouter | gemini | auto
AI_AUTOMATION_PROVIDER=auto

# Optional verification URL included in targeted announcements
AI_VERIFICATION_LINK=

# Network timeout for automation model calls (seconds)
AI_AUTOMATION_TIMEOUT_SECONDS=8

# Groq (fast inference)
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_FAST_MODELS=llama-3.1-8b-instant,llama-3.3-70b-versatile

# OpenRouter fallback (used when Groq is unavailable in auto mode)
AI_OPENROUTER_API_URL=https://openrouter.ai/api/v1/chat/completions
AI_OPENROUTER_API_KEY=
AI_OPENROUTER_MODEL=openrouter/auto

# Gemini fallback (used when Groq/OpenRouter are unavailable in auto mode)
AI_GEMINI_API_KEY=
AI_GEMINI_MODEL=gemini-2.0-flash
